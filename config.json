{
  "paths": {
    "dataset_dir": "data/raw",
    "processed_dir": "data/processed",
    "model_dir": "models/v1",
    "overwrite_dataset": false
  },
  "solver": {
    "M": 42,
    "dt_seconds": 120.0,
    "default_time_days": 100.0,
    "starttime_index": 2
  },
  "geometry": {
    "flip_latitude_to_north_south": true,
    "roll_longitude_to_0_2pi": true
  },
  "sampling": {
    "seed": 42,
    "n_sims": 100,
    "burn_in_days": 0.0,
    "transitions_per_simulation": 128,
    "transition_jump_days_min": 0.1,
    "transition_jump_days_max": 100.0,
    "parameters": [
      { "name": "a_m", "dist": "fixed", "value": 82000000.0 },
      { "name": "omega_rad_s", "dist": "fixed", "value": 0.000032 },
      { "name": "Phibar", "dist": "fixed", "value": 300000.0 },
      { "name": "DPhieq", "dist": "fixed", "value": 1000000.0 },
      { "name": "taurad_hours", "dist": "uniform", "min": 5.0, "max": 20.0},
      { "name": "taudrag_hours", "dist": "uniform", "min": 5.0, "max": 20.0},
      { "name": "g_m_s2", "dist": "fixed", "value": 9.8 }
    ]
  },
  "normalization": {
    "state": {
      "field_transforms": {
        "Phi": "signed_log1p",
        "U": "signed_log1p",
        "V": "signed_log1p",
        "eta": "signed_log1p",
        "delta": "signed_log1p"
      },
      "zscore_eps": 1e-8,
      "log10_eps": 1e-30,
      "signed_log1p_scale": 1.0
    },
    "params": {
      "mode": "zscore",
      "eps": 1e-8
    }
  },
  "model": {
    "grid": "legendre-gauss",
    "grid_internal": "legendre-gauss",
    "scale_factor": 2,
    "embed_dim": 256,
    "num_layers": 3,
    "encoder_layers": 3,
    "activation_function": "gelu",
    "use_mlp": true,
    "mlp_ratio": 2.0,
    "drop_rate": 0.0,
    "drop_path_rate": 0.0,
    "normalization_layer": "instance_norm",
    "hard_thresholding_fraction": 1.0,
    "residual_prediction": true,
    "residual_init_scale": 0.01,
    "pos_embed": "spectral",
    "bias": false,
    "include_coord_channels": true
  },
  "training": {
    "seed": 42,
    "device": "auto",
    "amp_mode": "none",
    "optimizer": "adamw",
    "epochs": 100,
    "batch_size": 32,
    "num_workers": 0,
    "shuffle": true,
    "pin_memory": false,
    "preload_to_gpu": false,
    "learning_rate": 1e-3,
    "weight_decay": 1e-5,
    "val_fraction": 0.1,
    "test_fraction": 0.1,
    "split_seed": 42,
    "scheduler": {
      "type": "plateau",
      "warmup_epochs": 10,
      "factor": 0.5,
      "patience": 10,
      "min_lr": 2e-5,
      "eps": 1e-10
    }
  }
}

{
  "paths": {
    "dataset_dir": "data/raw_1dt_smoketest",
    "processed_dir": "data/processed_1dt_smoketest",
    "model_dir": "models/onestep_1dt_v1_smoketest",
    "overwrite_dataset": true
  },
  "solver": {
    "M": 42,
    "dt_seconds": 120.0,
    "default_time_days": 6.0,
    "starttime_index": 2
  },
  "geometry": {
    "flip_latitude_to_north_south": true,
    "roll_longitude_to_0_2pi": true
  },
  "sampling": {
    "seed": 42,
    "n_sims": 8,
    "generation_workers": 0,
    "burn_in_days": 5.0,
    "saved_checkpoint_interval_days": 0.001388888888888889,
    "fixed_transition_steps": 1,
    "pairs_per_sim": 32,
    "pair_sampling_policy": "uniform_pairs",
    "live_transition_tolerance_fraction": 0.0,
    "parameters": [
      { "name": "a_m", "dist": "fixed", "value": 82000000.0 },
      { "name": "omega_rad_s", "dist": "fixed", "value": 0.000032 },
      { "name": "Phibar", "dist": "fixed", "value": 300000.0 },
      { "name": "DPhieq", "dist": "fixed", "value": 1000000.0 },
      { "name": "taurad_hours", "dist": "uniform", "min": 5.0, "max": 20.0},
      { "name": "taudrag_hours", "dist": "uniform", "min": 5.0, "max": 20.0},
      { "name": "g_m_s2", "dist": "fixed", "value": 9.8 }
    ]
  },
  "normalization": {
    "state": {
      "field_transforms": {
        "Phi": "signed_log1p",
        "U": "signed_log1p",
        "V": "signed_log1p",
        "eta": "signed_log1p",
        "delta": "signed_log1p"
      },
      "zscore_eps": 1e-8,
      "log10_eps": 1e-30,
      "signed_log1p_scale": 1.0
    },
    "params": {
      "mode": "zscore",
      "eps": 1e-8
    }
  },
  "model": {
    "grid": "legendre-gauss",
    "grid_internal": "legendre-gauss",
    "scale_factor": 2,
    "embed_dim": 384,
    "num_layers": 4,
    "encoder_layers": 3,
    "activation_function": "gelu",
    "use_mlp": true,
    "mlp_ratio": 2.0,
    "drop_rate": 0.0,
    "drop_path_rate": 0.0,
    "normalization_layer": "instance_norm",
    "hard_thresholding_fraction": 1.0,
    "residual_prediction": true,
    "include_coord_channels": true,
    "pos_embed": "spectral",
    "bias": false
  },
  "training": {
    "seed": 42,
    "device": "auto",
    "amp_mode": "none",
    "deterministic": false,
    "epochs": 3,
    "batch_size": 16,
    "num_workers": 0,
    "shuffle": true,
    "preload_to_gpu": true,
    "pair_iteration_mode": "resample_from_saved_sequences",
    "learning_rate": 2e-4,
    "weight_decay": 1e-5,
    "grad_clip_norm": 32.0,
    "val_fraction": 0.1,
    "test_fraction": 0.1,
    "split_seed": 42,
    "scheduler": {
      "type": "plateau",
      "warmup_epochs": 1,
      "factor": 0.5,
      "patience": 1,
      "min_lr": 5e-6,
      "eps": 1e-10
    }
  }
}
